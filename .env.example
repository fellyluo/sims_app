APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
LANGGANAN_PERINGATAN_INFO=14
LANGGANAN_PERINGATAN_KUNING=7
LANGGANAN_PERINGATAN_MERAH=3

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
BTIVE_FEEDBACK_EMAIL=btivesolution@gmail.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Firebase Cloud Messaging — path service account JSON (lihat storage/app/firebase/).
FIREBASE_CREDENTIALS=storage/app/firebase/service-account.json

# Asisten Guru — Gateway AI. Key HANYA di server; kosongkan = fitur AI mati.
AI_PROVIDER=gemini
GEMINI_API_KEY=
AI_MODEL=gemini-3.5-flash
# Limit Gemini bisa berupa RPM, TPM, dan RPD; nilainya berbeda per model/project.
# Bila model utama mengembalikan 429 karena kuota habis, GeminiService pindah ke model cadangan.
AI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-2.5-flash,gemini-2.5-flash-lite
# Router provider: bila SEMUA model provider utama kehabisan kuota atau providernya down,
# SIMS pindah ke provider cadangan ini (dilewati bila API key-nya kosong).
AI_FALLBACK_PROVIDERS=openrouter
AI_FREE_TIER_ONLY=true
AI_FREE_TIER_DAILY_LIMITS=gemini-3.5-flash:20,gemini-3.1-flash-lite:100,gemini-2.5-flash:250,gemini-2.5-flash-lite:1000
# Guard biaya (opsional, ada default di config/ai.php):
# AI_RATE_LIMIT=15
# AI_MAX_INPUT_CHARS=8000
# AI_MAX_OUTPUT_TOKENS=1024
# OpenRouter opsional. Untuk cegah saldo prabayar terpakai, biarkan OPENROUTER_FREE_ONLY=true
# dan gunakan hanya OPENROUTER_MODEL=openrouter/free atau model berakhiran :free.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_FALLBACK_MODELS=
OPENROUTER_FREE_ONLY=true
OPENROUTER_SITE_NAME="SIMS"
